# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb+srv://weventure_admin:abiwolf1994050505@cluster0.7hdwpcb.mongodb.net/weventurehub?retryWrites=true&w=majority

# JWT Security Secrets
JWT_ACCESS_SECRET=your-super-secret-enterprise-access-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-enterprise-refresh-key-minimum-32-chars

# Token Durations
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Payment Gateways Integration
CHAPA_SECRET_KEY=CHAPA_SEC_KEY_MOCK_SECRET_12345
CHAPA_WEBHOOK_SECRET=mock_webhook_secret_key_67890

# SMTP Email Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=mock-smtp-user
SMTP_PASS=mock-smtp-password
SMTP_FROM="WeVentureHub <noreply@weventurehub.com>"

